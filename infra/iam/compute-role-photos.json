{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowReadWriteHomePhotos",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::cristinegennaro.com/home/*"
    },
    {
      "Sid": "AllowListHomePhotos",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::cristinegennaro.com",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["home/*"]
        }
      }
    }
  ]
}
