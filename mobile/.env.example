# Copy to mobile/.env.local for local dev (npx expo start picks it up
# automatically). For EAS builds, mirror the same values into EAS
# Secrets:
#
#   npx eas-cli secret:create --scope project --name EXPO_PUBLIC_HA_BASE_URL --value "<url>"
#   npx eas-cli secret:create --scope project --name EXPO_PUBLIC_HA_TOKEN --value "<token>"
#
# Both files are gitignored. Anything prefixed EXPO_PUBLIC_ is embedded
# in the JS bundle at build time — anyone with the .ipa can extract
# them, so treat the threat model the same as a phone with the app
# installed.

EXPO_PUBLIC_HA_BASE_URL=https://abc123.ui.nabu.casa
EXPO_PUBLIC_HA_TOKEN=eyJ0eXAiOiJK...
