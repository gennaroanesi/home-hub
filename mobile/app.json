{
  "expo": {
    "name": "Home Hub",
    "slug": "home-hub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "homehub",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cristinegennaro.homehub",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocalNetworkUsageDescription": "Home Hub uses your home network to find and control Home Assistant directly when you're home.",
        "NSBonjourServices": [
          "_home-assistant._tcp"
        ],
        "NSAppTransportSecurity": {
          "NSExceptionDomains": {
            "homeassistant.local": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            }
          }
        },
        "NSPhotoLibraryUsageDescription": "Home Hub uses your photo library to attach images to messages with Janet.",
        "NSCameraUsageDescription": "Home Hub uses your camera to take photos to attach to messages with Janet."
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Home Hub uses Face ID to confirm sensitive actions like document downloads."
        }
      ],
      ["./plugins/with-share-extension-display-name", "Home Hub"],
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsImageWithMaxCount": 1,
            "NSExtensionActivationSupportsFileWithMaxCount": 1
          },
          "iosShareExtensionName": "ShareExtension"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e7781de0-8c4b-40ee-9f08-bb1d0fc78bf7"
      }
    },
    "owner": "gennaroanesi"
  }
}
